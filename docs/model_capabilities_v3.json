      "constraints": {
        "gpu_recommendation": "high",
        "max_recommended_rows": 10000,
        "min_rows": 100
      },
      "performance": {
        "training_speed": "slow",
        "inference_speed": "slow",
        "memory_usage": "high"
      },
      "description": "LLM-based synthesizer using GPT-2. Excellent for extreme skew, high cardinality, and Zipfian distributions. Best overall model for complex data but slow on large datasets.",
      "strengths": [
        "Handles extreme skewness (>4.0) better than any model",
        "Superior rare category capture (Zipfian distributions)",
        "Excellent high cardinality handling (>5000 unique values)",
        "Captures complex semantic relationships"
      ],
      "limitations": [
        "Very slow training (hours for 10k+ rows)",
        "High memory requirements",
        "Not suitable for large datasets (>10k rows in practice)",
        "Strongly benefits from GPU (high recommendation)"
      ]
    },
